trade_note <- if (nrow(trade_hit) > 0) {
sprintf("Spearman con Golpes/min: rho=%.2f, p=%s, q=%s", trade_hit$rho[1], fmt_p(trade_hit$p_value[1]), fmt_p(trade_hit$q_value[1]))
} else {
""
}
draw_legacy_box(
